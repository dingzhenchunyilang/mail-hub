# Mail Hub 配置文件
# 复制此文件为 .env 并填入实际值

# 服务器端口
PORT=3000

# 加密密钥（必填，用于加密邮箱密码）
# 生成命令: openssl rand -hex 32
ENCRYPTION_KEY=

# 数据库路径（默认: ./data/mail-hub.db）
DB_PATH=./data/mail-hub.db

# 邮件同步间隔（cron 表达式，默认每5分钟）
SYNC_INTERVAL=*/5 * * * *

# 禁用同步服务（调试用）
# DISABLE_SYNC=true

# AI 功能配置（阶段四）
# 支持 OpenAI 兼容 API（OpenAI、DeepSeek、Claude 等）
AI_PROVIDER=openai
AI_API_KEY=
AI_B...
